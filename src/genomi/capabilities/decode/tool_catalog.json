{
  "capabilities": {
    "decode": {
      "title": "Genomi Dashboard (decode)",
      "start_when": "The agent runs the /genomi decode kicker or otherwise needs Genomi to build and render the consolidated Genomi Dashboard HTML artifact.",
      "skill_documents": [
        "skills/decode/SKILL.md"
      ],
      "entry_operations": [
        "decode.render_dashboard"
      ],
      "operations": [
        "decode.build_dashboard_evidence",
        "decode.render_dashboard"
      ]
    }
  },
  "operations": {
    "decode.build_dashboard_evidence": {
      "capability": "decode",
      "namespace": "decode",
      "description": "Build Genomi Dashboard panel states from the approved Active Genome Index and existing capability operations. Used by decode.render_dashboard; presented output reports panel readiness, running jobs, and gaps.",
      "input_schema": {
        "type": "object",
        "x_genomi_property_groups": ["decode_dashboard_options"],
        "properties": {},
        "required": [],
        "additionalProperties": false
      },
      "skill": "skills/decode/SKILL.md",
      "area": "decode",
      "requires": [
        "active_genome_index"
      ],
      "produces": [
        "dashboard_panel_state"
      ],
      "context_optional": [
        "risk_score_ids",
        "nutrigenomics_domain_ids"
      ],
      "privacy_scope": "active_genome_index",
      "operation_scope": "write",
      "mutating": true,
      "external_io": [],
      "optional_libraries": [
        "clinvar-grch38",
        "pharmcat",
        "ancestry-1000g-30x-grch38"
      ],
      "library_check_operation": "genomi.check_libraries",
      "data_access": [
        "active_genome_index",
        "public_catalog_metadata",
        "installed_public_reference_panel"
      ],
      "discovery_role": "support_tool"
    },
    "decode.render_dashboard": {
      "capability": "decode",
      "namespace": "decode",
      "description": "Build, shape, render, and expose the Genomi Dashboard self-contained HTML artifact from the approved Active Genome Index.",
      "input_schema": {
        "type": "object",
        "x_genomi_property_groups": ["decode_dashboard_options"],
        "properties": {
          "output": {
            "$ref": "#/schema_fragments/properties/local_path",
            "description": "Optional override for the dashboard HTML path. Defaults to a transient path under the system temp dir: <tmp>/genomi-dashboards/<sample>/dashboard.html."
          }
        },
        "required": [],
        "additionalProperties": false
      },
      "skill": "skills/decode/SKILL.md",
      "area": "decode",
      "requires": [
        "active_genome_index"
      ],
      "produces": [
        "dashboard_artifact"
      ],
      "context_optional": [
        "work_dir"
      ],
      "privacy_scope": "active_genome_index",
      "operation_scope": "write",
      "mutating": true,
      "external_io": [],
      "data_access": [
        "active_genome_index"
      ],
      "discovery_role": "entry_tool",
      "dependencyContract": {
        "localResources": [
          "active_genome_index"
        ]
      }
    }
  }
