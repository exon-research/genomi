    "phenotype.retrieve_disease_drug_targets": {
      "capability": "phenotype-gene",
      "namespace": "phenotype",
      "description": "Retrieve disease-scoped clinical drug-target genes from Open Targets drug candidate records.",
      "input_schema": {
