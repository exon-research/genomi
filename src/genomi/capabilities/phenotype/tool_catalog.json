            "type": "string",
            "enum": [
              "records",
              "gene_membership"
            ],
            "default": "records"
          },
          "minimum_clinical_stage": {
            "type": "string",
            "default": "PHASE_2"
          },
          "opentargets_api_url": {
            "type": "string",
            "default": "https://api.platform.opentargets.org/api/v4/graphql"
          },
          "limit": {
            "$ref": "#/schema_fragments/properties/limit_100"
          },
          "semantic_context": {
            "$ref": "#/schema_fragments/properties/semantic_context"
          }
        },
        "required": [],
