  "operations": {
    "pharmacogenomics.describe_gene_requirements": {
      "capability": "pharmacogenomics",
      "namespace": "pharmacogenomics",
      "description": "Return pharmacogene-specific sample evidence requirements for PharmCAT named allele matching, outside calls, CYP2D6 SV/CNV handling, HLA typing, MT-RNR1, and G6PD chrX representation.",
      "input_schema": {
        "type": "object",
        "properties": {
          "gene": {
            "type": "string"
          },
          "refresh_sources": {
            "type": "boolean",
            "default": false
          },
          "pharmcat_genes_drugs_url": {
            "type": "string",
            "default": "https://pharmcat.clinpgx.org/Genes-Drugs/"
          },
          "semantic_context": {
            "$ref": "#/schema_fragments/properties/semantic_context"
          }
        },
        "required": [],
        "additionalProperties": false
      },
      "skill": "skills/pharmacogenomics/SKILL.md",
      "area": "pharmacogenomics",
      "requires": [],
      "produces": [
        "pharmacogene_requirement_catalog",
        "pgx_sample_evidence_requirements",
        "source_document_references",
        "optional_live_source_snapshot"
      ],
      "context_optional": [],
      "privacy_scope": "metadata_only",
      "operation_scope": "read",
      "mutating": false,
      "external_io": [
        "pharmcat_documentation_web_when_refresh_sources_true"
      ],
      "data_access": [
        "local_artifact_metadata",
        "public_catalog_metadata"
      ],
      "discovery_role": "focused_tool"
    },
    "pharmacogenomics.review_medication": {
      "capability": "pharmacogenomics",
      "namespace": "pharmacogenomics",
      "description": "Review medication pharmacogenomic evidence by combining ClinPGx guideline/label context, FDA PGx table rows, PGxDB association evidence, Active Genome Index rsID lookup when selected, implemented marker-definition evidence when selected, evidence components, and target inventory.",
      "input_schema": {
        "type": "object",
        "properties": {
          "indication": {
            "type": "string"
          },
          "dose": {
            "type": "string"
          },
          "current_medications": {
            "type": "string"
          },
          "allergies_or_contraindications": {
            "type": "string"
          },
          "known_genotype": {
            "type": "string"
          },
          "known_diplotype": {
            "type": "string"
          },
          "known_phenotype": {
            "type": "string"
          },
          "known_activity_score": {
            "type": "string"
          },
          "known_pgx_source": {
            "type": "string"
          },
          "semantic_context": {
            "$ref": "#/schema_fragments/properties/semantic_context"
          },
          "genome_build": {
            "$ref": "#/schema_fragments/properties/genome_build_grch38_contextual"
          },
          "include_active_genome_index": {
            "type": "boolean",
            "x_genomi_default": {
              "rule": "true when explicit/private active genome context is available; otherwise false",
              "source": "contextual_default",
              "possible_values": [
                false,
                true
              ]
            }
          },
          "include_known_active_genome_indexes": {
            "$ref": "#/schema_fragments/properties/include_known_active_genome_indexes"
          },
          "include_stored_research": {
            "$ref": "#/schema_fragments/properties/boolean_default_true"
          },
          "include_record_research_payloads": {
            "$ref": "#/schema_fragments/properties/boolean_default_false"
          },
          "limit": {
            "type": "integer",
            "default": 10
          },
          "clinpgx_api_url": {
            "type": "string",
            "default": "https://api.pharmgkb.org/v1"
          },
          "pgxdb_api_url": {
            "type": "string",
            "default": "https://pgx-db.org/rest-api"
          },
          "fda_biomarkers_url": {
            "type": "string",
            "default": "https://www.fda.gov/drugs/science-and-research-drugs/table-pharmacogenomic-biomarkers-drug-labeling"
          },
          "fda_associations_url": {
            "type": "string",
            "default": "https://www.fda.gov/medical-devices/precision-medicine/table-pharmacogenetic-associations"
          }
        },
        "required": [],
        "additionalProperties": false,
        "x_genomi_property_groups": [
          "storage_db_pair",
          "pgx_drug_gene_variant_target"
        ]
      },
      "skill": "skills/pharmacogenomics/SKILL.md",
      "area": "pharmacogenomics",
      "requires": [
        "selected_medication"
      ],
      "produces": [
        "pharmacogenomic_medication_review",
        "pgx_unanswered_answer_components",
        "pgx_answer_support",
        "pgx_evidence_components",
        "pgx_target_inventory",
        "pgx_evidence_matrix",
        "pgx_evidence_envelope",
        "pgx_evidence_traceability",
        "pgx_evidence_state",
        "candidate_matrix",
        "evidence_view",
        "decision_evidence",
        "top_observed_candidate",
        "sample_variant_evidence",
        "sample_marker_definition_evidence",
        "public_pgx_evidence",
        "fda_pharmacogenomic_table_evidence",
        "record_research_payloads"
      ],
      "context_optional": [],
      "privacy_scope": "target_scoped",
      "operation_scope": "read",
      "mutating": false,
      "external_io": [
        "clinpgx_api",
        "pgxdb_api",
        "fda_web"
      ],
      "data_access": [
        "selected_public_targets",
        "active_genome_index_when_selected"
      ],
      "discovery_role": "entry_tool"
    },
