      "capability": "functional-genomics",
      "namespace": "functional_genomics",
      "description": "Retrieve native public functional-genomics perturbation records from BioGRID ORCS and DepMap for candidate genes and declared experimental context.",
      "input_schema": {
        "type": "object",
        "properties": {
          "limit": {
            "$ref": "#/schema_fragments/properties/limit_100"
          },
          "semantic_context": {
            "$ref": "#/schema_fragments/properties/semantic_context"
          }
        },
        "required": [
          "context",
          "genes"
        ],
        "additionalProperties": false,
        "x_genomi_property_groups": [
          "functional_perturbation_context",
          "functional_native_sources"
        ]
      },
      "skill": "skills/functional-genomics/SKILL.md",
      "area": "functional_genomics",
      "requires": [
        "candidate_genes",
        "perturbation_context"
      ],
      "produces": [
        "source_records",
        "direct_perturbation_source_records",
        "records_by_gene",
        "coverage_state",
        "source_coverage"
      ],
      "context_optional": [],
      "privacy_scope": "public_target_only",
      "operation_scope": "read",
      "mutating": false,
      "external_io": [
        "biogrid_orcs_api",
        "depmap_public_download"
      ],
      "data_access": [
        "selected_public_targets"
      ],
      "discovery_role": "focused_tool"
    },
