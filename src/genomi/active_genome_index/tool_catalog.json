    "active_genome_index.build_reference_pass": {
      "capability": "active-genome-index",
      "namespace": "active_genome_index",
      "description": "Internal: append the gVCF reference-block tail (Phase B) to a variants_ready Active Genome Index and flip it to completed. Launched automatically as a background job by genomi.parse_source; not normally invoked by hand.",
      "input_schema": {
        "type": "object",
        "properties": {
          "agi_path": {
            "$ref": "#/schema_fragments/properties/local_path"
          },
          "parallel_workers": {
            "type": "integer",
            "minimum": 1
          }
        },
        "required": [
          "agi_path"
        ],
        "additionalProperties": false
      },
      "skill": "skills/active-genome-index/SKILL.md",
      "area": "active_genome_index",
      "requires": [],
      "produces": [
        "active_genome_index_build_status"
      ],
      "context_optional": [],
      "privacy_scope": "local_private",
      "operation_scope": "write",
      "mutating": true,
      "external_io": [],
      "data_access": [
        "active_genome_index"
      ],
      "discovery_role": "internal_tool"
    },
